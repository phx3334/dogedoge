# ============================================================
# 服务器部署环境变量模板
# 复制为 /opt/fake_tiktok/.env 并填写（已被 .gitignore 忽略，切勿提交）
#
# - compose 用 MYSQL_*/RABBITMQ_*/REDIS_PASSWORD/GHCR_OWNER 做变量替换
# - api/worker 容器通过 env_file 读取 APP_* 注入业务配置
# - GHCR_OWNER 需等于你的 GitHub 用户名（小写），与 Actions 推送的镜像一致
# ============================================================

GHCR_OWNER=

# ---------------- 基础设施密码（需与下方对应 APP_* 一致） ----------------
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASSWORD=
# 注意：redis 实际密码写死在 deploy/redis/redis.conf（147258），
# 改密码需同步该文件与 APP_REDIS_PASSWORD；这里仅用于健康检查
REDIS_PASSWORD=

# ---------------- Server / JWT / Session 密钥（必填，自己生成随机串） ----------------
APP_SERVER_SESSIONS_SECRET=
APP_JWT_ACCESS_TOKEN_SECRET=
APP_JWT_REFRESH_TOKEN_SECRET=

# ---------------- Email（QQ SMTP 授权码） ----------------
APP_EMAIL_SECRET=

# ---------------- Database（HOST/PORT 由 compose 覆盖为 mysql/3306） ----------------
APP_DATABASE_PASSWORD=
APP_DATABASE_DBNAME=

# ---------------- Redis（HOST/PORT 由 compose 覆盖为 redis/6379） ----------------
APP_REDIS_PASSWORD=
APP_REDIS_DB=
APP_REDIS_KEY_PREFIX=

# ---------------- RabbitMQ（HOST/PORT 由 compose 覆盖为 rabbitmq/5672） ----------------
APP_RABBITMQ_USERNAME=
APP_RABBITMQ_PASSWORD=

# ---------------- Elasticsearch ----------------
APP_ELASTICSEARCH_HOST=
APP_ELASTICSEARCH_PASSWORD=

# ---------------- Gaode Map ----------------
APP_GAODE_API_KEY=

# ---------------- 存储（七牛云对象存储） ----------------
APP_STORAGE_DRIVER=
APP_QINIU_ZONE=
APP_QINIU_BUCKET=
APP_QINIU_DOMAIN=
APP_QINIU_ACCESS_KEY=
APP_QINIU_SECRET_KEY=
# 先部署阶段保持 false；待 bucket 域名配好 HTTPS 证书后再改为 true
APP_QINIU_USE_HTTPS=
# 待上传走七牛 CDN 加速域名确认无误后再改为 true
APP_QINIU_USE_CDN_DOMAINS=

# ---------------- AI 聊天（OpenAI 兼容接口，DeepSeek） ----------------
APP_AI_API_KEY=
APP_AI_BASE_URL=
APP_AI_MODEL=

# ---------------- 首次部署建表（建好后改回 false） ----------------
APP_DATABASE_AUTO_MIGRATE=
